{
  "name": "gupshup-monorepo",
  "version": "1.0.0",
  "description": "Gupshup Discord Bot & Dashboard — Monorepo",
  "private": true,
  "workspaces": [
    "apps/bot",
    "apps/dashboard"
  ],
  "scripts": {
    "dev:bot": "tsx watch apps/bot/src/index.ts",
    "dev:dashboard": "npm run dev --prefix apps/dashboard",
    "build:bot": "tsc -p apps/bot/tsconfig.json",
    "build:dashboard": "npm run build --prefix apps/dashboard",
    "start:bot": "node apps/bot/dist/index.js",
    "start:dashboard": "npm run start --prefix apps/dashboard",
    "lint": "eslint apps/bot/src/**/*.ts",
    "format": "prettier --write \"apps/bot/src/**/*.ts\" \"apps/dashboard/src/**/*.{ts,tsx}\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.53",
    "@prisma/client": "^5.16.0",
    "bullmq": "^5.8.5",
    "cors": "^2.8.5",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "eslint": "^9.6.0",
    "prettier": "^3.3.2",
    "prisma": "^5.16.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2"
  }
}
